ant).","jabachInventory":"","napoleonInventory":"","previousOwner":[],"acquisitionDetails":[],"ownedBy":"","heldBy":"","longTermLoanTo":"","index":{"person":[{"value":"Lavater, Johann Kaspar"}],"technic":[{"value":"pastel"}]},"bibliography":[],"exhibition":[],"relatedWork":[],"image":[{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/original\/10\/92\/63\/00\/AGO109263-000_PE.jpg","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/10\/92\/63\/00\/AGO109263-000_PE.jpg","copyright":"GrandPalaisRmn (Mus\u00e9e du Louvre) \/ Michel Urtado","type":"","position":0},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/original\/10\/92\/63\/00\/AGO109263-001_PE.jpg","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/10\/92\/63\/00\/AGO109263-001_PE.jpg","copyright":"GrandPalaisRmn \/ Mich\u00e8le Bellot","type":"Autre","position":1}]}