 tranches du livre.","inscriptions":"","namesAndTitles":"","onomastics":"","dimension":[{"type":"Hauteur","value":"3,2","displayDimension":"3,2 cm","unit":"cm","anteriorPrecision":"","posteriorPrecision":"","tri":1,"note":""},{"type":"Largeur","value":"3","displayDimension":"3 cm","unit":"cm","anteriorPrecision":"","posteriorPrecision":"","tri":1,"note":""},{"type":"Profondeur","value":"1,8","displayDimension":"1,8 cm","unit":"cm","anteriorPrecision":"","posteriorPrecision":"","tri":1,"note":""}],"shape":"","materialsAndTechniques":"Mat\u00e9riau : cuivre\r\nTechnique : dor\u00e9 = dorure (techniques m\u00e9tal)\r\nTechnique : cisel\u00e9 = ciselure (techniques m\u00e9tal)\r\nTechnique : peinture sous cristal de roche (techniques pierre\/ciment\/pl\u00e2tre\/cire-\u003Epeint)\r\nMat\u00e9riau : or","placeOfCreation":"Italie (Europe)","dateOfDiscovery":"","placeOfDiscovery":"","provenance":"","historicalContext":[],"objectHistory":"Cf. Inventaire 9DD6 (OA 2586-59999) p. 135 : \u0022[D\u00e9signation des objets] Petit reliquaire, monture de bronze dor\u00e9, d\u00e9cor\u00e9 \u00e0 l\u0027int\u00e9rieur de plaques de verre peint, dit \u00e9glomis\u00e9. France XVe - XVIe s. \/ [Mati\u00e8re] orf\u00e8vrerie \/ [Estimation] 500 F \/ [Observations] acquis de M. Peltier 28 Faubg de Rouen \u00e0 \/ Louviers 500 F \/ f\u00e9vrier 1901\u0022","jabachInventory":"","napoleonInventory":"","previousOwner":[{"value":"Peltier","note":"","role":", Collectionneur"}],"acquisitionDetails":[{"mode":"achat","doubt":"","dates":[{"type":"date","value":"02\/1901","startYear":1901,"endYear":1901}]}],"ownedBy":"Etat","heldBy":"Mus\u00e9e du Louvre, D\u00e9partement des Objets d\u0027art du Moyen Age, de la Renaissance et des temps modernes","longTermLoanTo":"","index":{"Mode d\u0027acquisition":[{"value":"achat"}],"place":[{"value":"Italie"}],"objectType":[{"value":"pendentif"}]},"bibliography":[],"exhibition":[],"relatedWork":[],"image":[{"urlImage":"https:\/\/collections.louvre.fr\/media\