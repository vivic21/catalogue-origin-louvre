cle mobile du r\u00e9veil grav\u00e9 d\u0027une rosace. Mouvement muni d\u0027un foliot droit et d\u0027un stackfreed ; ressorts-moteurs non prot\u00e9g\u00e9s par des barillets. Timbre viss\u00e9 au fond du bo\u00eetier.","inscriptions":"Poin\u00e7on : \r ; sur la carrure : HG","namesAndTitles":"","onomastics":"","dimension":[{"type":"Hauteur","value":"2,5","displayDimension":"2,5 cm","unit":"cm","anteriorPrecision":"","posteriorPrecision":"","tri":1,"note":""},{"type":"Diam\u00e8tre","value":"6,7","displayDimension":"6,7 cm","unit":"cm","anteriorPrecision":"","posteriorPrecision":"","tri":2,"note":""}],"shape":"","materialsAndTechniques":"Mat\u00e9riau : acier\r\nMat\u00e9riau : laiton","placeOfCreation":"Allemagne (Europe)","dateOfDiscovery":"","placeOfDiscovery":"","provenance":"","historicalContext":[],"objectHistory":"Collection Claudius C\u00f4te (1881-1956), Lyon ; legs Mme Marie-Fran\u00e7oise C\u00f4te, accept\u00e9 par d\u00e9cret du 9 juillet 1961","jabachInventory":"","napoleonInventory":"","previousOwner":[{"value":"Mme C\u00f4te, Marie-Fran\u00e7oise","note":"","role":", L\u00e9gataire"},{"value":"M. C\u00f4te, Claudius","note":"","role":", Collectionneur"}],"acquisitionDetails":[{"mode":"legs","doubt":"","dates":[{"type":"date du legs","value":"1961","startYear":1961,"endYear":1961},{"type":"date de comit\u00e9\/commission","value":"02\/02\/1961","startYear":1961,"endYear":1961},{"type":"date du conseil","value":"16\/02\/1961","startYear":1961,"endYear":1961},{"type":"date du d\u00e9cret","value":"09\/07\/1961","startYear":1961,"endYear":1961}]}],"ownedBy":"Etat","heldBy":"Mus\u00e9e du Louvre, D\u00e9partement des Objets d\u0027art du Moyen Age, de la Renaissance et des temps modernes","longTermLoanTo":"","index":{"Mode d\u0027acquisition":[{"value":"legs"}],"period":[{"value":"Henri II (1547-1559)"},{"value":"Fran\u00e7ois II (1559-1560)"}],"place":[{"value":"Allemagne"}],"objectType":[{"value":"horlogerie"},{"value":"montre"}]},"bibliography":[{"b