{"arkId":"cl010093423","url":"https:\/\/collections.louvre.fr\/ark:\/53355\/cl010093423","modified ":"2025-08-25","title":"Saint Nicaise","titleComplement":"","denominationTitle":[{"type":"Titre","value":"Saint Nicaise"}],"displayDateCreated":"Date de cr\u00e9ation\/fabrication : 1450 - 1500","currentLocation":"non expos\u00e9","room":"","isMuseesNationauxRecuperation":false,"dateCreated":[{"startYear":1450,"endYear":1500,"imprecision":"","text":"2e moiti\u00e9 du XVe si\u00e8cle","type":"Date de cr\u00e9ation\/fabrication","doubt":""}],"creator":[{"label":"France Champagne","attributionLevel":"Attribution actuelle","linkType":"","creatorRole":"","authenticationType":"","doubt":"","attributedBy":"","attributedYear":"","wikidata":""}],"objectNumber":[{"value":"RF 1051","type":"Num\u00e9ro principal"}],"collection":"D\u00e9partement des Sculptures du Moyen Age, de la Renaissance et des temps modernes","printsDrawingsEntity":"","printsDrawingsCollection":"","objectType":"statuette","originalObject":"","printState":"","description":"","inscriptions":"","namesAndTitles":"","onomastics":"","dimension":[{"type":"Hauteur","value":"0,785","displayDimension":"0,785 m","unit":"m","anteriorPrecision":"","posteriorPrecision":"","tri":1,"note":""},{"type":"Largeur","value":"0,24","displayDimension":"0,24 m","unit":"m","anteriorPrecision":"","posteriorPrecision":"","tri":2,"note":""},{"type":"Profondeur","value":"0,24","displayDimension":"0,24 m","unit":"m","anteriorPrecision":"","posteriorPrecision":"","tri":3,"note":""}],"shape":"","materialsAndTechniques":"pierre traces de polychromie","placeOfCreation":"","dateOfDiscovery":"","placeOfDiscovery":"","provenance":"","historicalContext":[],"objectHistory":"Aurait \u00e9t\u00e9, selon le donateur, acquis \u00e0 Reims comme provenant de l\u0027ancienne abbaye b\u00e9n\u00e9dictine Saint-Nicaise, devenue bien national \u00e0 la R\u00e9volution. \r\nB\u00e2timents vendus le 22 mars 1791 \u00e0 Louis Eccart. Vente non r\u00e9alis\u00e9e. Locaux destin\u00e9s alors \u00e0 abriter un h\u00f4pital. Nouvelle adjudication  faite le 24 d\u00e9cembre 1798 \u00e0 J. S. Defienne, pour le compte du g\u00e9n\u00e9ral Jacques Antoine Santerre. \r\nBien retourn\u00e9 \u00e0 l\u0027Etat en 1805, vendu le 12 ao\u00fbt 1805 au sieur Correau, de Reims. D\u00e9mant\u00e8lement de l\u0027\u00e9glise entrepris en 1792. D\u00e9molition de l\u0027ensemble des b\u00e2timents effectu\u00e9e en 1799. \r\nCollection Carlo Micheli (+1895), Paris. Don de Marie Micheli en souvenir de son p\u00e8re, 1895 (comit\u00e9 du 7 f\u00e9vrier 1895, autorisation minist\u00e9rielle du 15 mars 1895).","jabachInventory":"","napoleonInventory":"","previousOwner":[{"value":"Micheli, Carlo","note":"","role":", Collectionneur"},{"value":"Mme Micheli, Marie","note":"","role":", Donateur"}],"acquisitionDetails":[{"mode":"don","doubt":"","dates":[{"type":"date de comit\u00e9\/commission","value":"07\/02\/1895","startYear":1895,"endYear":1895},{"type":"autres dates","value":"15\/03\/1895","startYear":1895,"endYear":1895}]}],"ownedBy":"Etat","heldBy":"Mus\u00e9e du Louvre, D\u00e9partement des Sculptures du Moyen Age, de la Renaissance et des temps modernes","longTermLoanTo":"","index":{"Mode d\u0027acquisition":[{"value":"don"}],"material":[{"value":"pierre"}],"technic":[{"value":"traces de polychromie"}],"objectType":[{"value":"statuette"}]},"bibliography":[{"bibliographyRef":"Baron, Fran\u00e7oise, Mus\u00e9e du Louvre - Sculpture fran\u00e7aise - I - Moyen Age, Paris, 1996","bibliographyDate":"1996","bibliographyDetail":"p. 178","comparison":false},{"bibliographyRef":"Aubert, Marcel ; Beaulieu, Mich\u00e8le, Mus\u00e9e national du Louvre. Description raisonn\u00e9e des Sculptures du Moyen \u00c2ge, de la Renaissance et des Temps modernes, t. 1, Moyen \u00c2ge, Paris, 1950","bibliographyDate":"1950","bibliographyDetail":"n\u00b0 295","comparison":false},{"bibliographyRef":"Vitry, Paul, Catalogue des sculptures du Moyen \u00c2ge, de la Renaissa