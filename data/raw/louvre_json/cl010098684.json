95 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Daniel Arnaudet","type":"dos, verso, revers, arri\u00e8re ; ouvert","position":4},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235950_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000098684\/0000235950_OG.JPG","copyright":"\u00a9 1990 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Martine Beck-Coppola","type":"","position":5},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235951_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000098684\/0000235951_OG.JPG","copyright":"\u00a9 1990 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Martine Beck-Coppola","type":"","position":6},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235952_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000098684\/0000235952_OG.JPG","copyright":"\u00a9 1990 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Martine Beck-Coppola","type":"","position":7},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235953_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000098684\/0000235953_OG.JPG","copyright":"\u00a9 1990 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Martine Beck-Coppola","type":"","position":8},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235967_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000098684\/0000235967_OG.JPG","copyright":"\u00a9 1990 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Martine Beck-Coppola","type":"","position":9},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000098684\/0000235949_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/s