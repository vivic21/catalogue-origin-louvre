{"arkId":"cl020211078","url":"https:\/\/collections.louvre.fr\/ark:\/53355\/cl020211078","modified ":"2025-08-19","title":"Vue de Rochefort","titleComplement":null,"denominationTitle":[{"type":"Titre","value":"Vue de Rochefort"}],"displayDateCreated":"","currentLocation":"Petit format","room":"","isMuseesNationauxRecuperation":false,"dateCreated":[],"creator":[{"label":"OZANNE l\u0027un des","attributionLevel":"attribution actuelle","linkType":"original","dates":[{"date":"1728","place":"","type":"date 1"},{"date":"1813","place":"","type":"date 2"}],"creatorRole":"","authenticationType":"","doubt":"","attributedBy":"","attributedYear":"","wikidata":""}],"objectNumber":[{"value":"INV 31785, Recto","type":"Num\u00e9ro principal"},{"value":"NIII 32621","type":"Anciens num\u00e9ros d\u0027inventaire"},{"value":"vol.13, p.143","type":"R\u00e9f\u00e9rence de l\u0027inventaire manuscrit"}],"collection":"D\u00e9partement des Arts graphiques","printsDrawingsEntity":"Cabinet des dessins","printsDrawingsCollection":"Fonds des dessins et miniatures","objectType":"","originalObject":"","printState":"","description":"","inscriptions":"","namesAndTitles":"","onomastics":"","dimension":[{"type":"Hauteur","value":"0.22","displayDimension":"0.22 m","unit":"m","anteriorPrecision":"\u00e0 la feuille","posteriorPrecision":"","tri":"","note":""},{"type":"Largeur","value":"0.14","displayDimension":"0.14 m","unit":"m","anteriorPrecision":"\u00e0 la feuille","posteriorPrecision":"","tri":"","note":""}],"shape":"","materialsAndTechniques":"Plume encre noire, lavis gris","placeOfCreation":"","dateOfDiscovery":"","placeOfDiscovery":"","provenance":"","historicalContext":[],"objectHistory":"Non retrouv\u00e9 lors des r\u00e9colements. Non vu au r\u00e9colement du Mus\u00e9e de la Marine par le Minist\u00e8re de la D\u00e9fense, 21\/11\/1998. \nCe dessin est rentr\u00e9 au mus\u00e9e du Louvre le 9 f\u00e9vrier 2024. Ce dessin propos\u00e9 \u00e0 la vente du 17 mai 2023 sous le num\u00e9ro de lot