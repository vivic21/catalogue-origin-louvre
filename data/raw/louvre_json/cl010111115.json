.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366422_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":18},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366423_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366423_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":19},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366424_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366424_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":20},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366425_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366425_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":21},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366426_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366426_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":22},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366427_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366427_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":23},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366428_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366428_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":24},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0001366429_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0001366429_OG.JPG","copyright":"\u00a9 2025 GrandPalaisRmn (mus\u00e9e du Louvre) \/ Sylvie Chan-Liat","type":"","position":25},{"urlImage":"https:\/\/collections.louvre.fr\/media\/cache\/large\/0000000021\/0000111115\/0000238679_OG.JPG","urlThumbnail":"https:\/\/collections.louvre.fr\/media\/cache\/small\/0000000021\/0000111115\/0000238679_OG.JPG","copyright":"\u00a9 2011 Mus\u00e9e du Louvre, Dist. GrandPalaisRmn \/ Philippe Fuzeau","type":"","position":26}]}